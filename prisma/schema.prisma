generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          String    @default("BUYER")
  company       String?
  country       String?
  createdAt     DateTime  @default(now())
  orders        Order[]
  favorites     Favorite[]
}

model Supplier {
  id            String    @id @default(cuid())
  name          String
  nameEn        String?
  address       String?
  city          String?
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  certifications String?
  createdAt     DateTime  @default(now())
  products      Product[]
  orders        Order[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Product {
  id          String     @id @default(cuid())
  supplierId  String
  categoryId  String?
  name        String
  nameEn      String?
  sku         String?
  description String?
  hsCode      String?
  unit        String     @default("PCS")
  price       Float
  moq         Int        @default(1)
  leadDays    Int?
  origin      String     @default("China")
  imageUrl    String?
  specs       String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  supplier    Supplier   @relation(fields: [supplierId], references: [id])
  category    Category?  @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  favorites   Favorite[]
}

model Order {
  id             String      @id @default(cuid())
  orderNo        String      @unique
  buyerId        String
  supplierId     String
  status         String      @default("QUOTE")
  paymentTerms   String?
  shippingTerms  String?
  portOfLoading  String?
  portOfDischarge String?
  notes          String?
  totalAmount    Float       @default(0)
  currency       String      @default("USD")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  buyer          User        @relation(fields: [buyerId], references: [id])
  supplier       Supplier    @relation(fields: [supplierId], references: [id])
  items          OrderItem[]
  documents      Document[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  description String?
  hsCode      String?
  quantity    Float
  unit        String   @default("PCS")
  unitPrice   Float
  totalPrice  Float
  boxes       Int?
  netWeight   Float?
  grossWeight Float?
  cbm         Float?
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

model Document {
  id        String   @id @default(cuid())
  orderId   String
  type      String
  docNo     String   @unique
  issuedAt  DateTime @default(now())
  data      String
  order     Order    @relation(fields: [orderId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  @@unique([userId, productId])
}
